{
  "name": "ai-camp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @ai-camp/api dev",
    "dev:web": "pnpm --filter @ai-camp/web dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel --filter \"./apps/*\" start",
    "db:push": "pnpm --filter @ai-camp/api db:push",
    "db:migrate": "pnpm --filter @ai-camp/api db:migrate",
    "db:seed": "pnpm --filter @ai-camp/api db:seed",
    "db:reset": "pnpm --filter @ai-camp/api db:reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  }
}
