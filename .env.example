# ---- App ----
NODE_ENV=development
WEB_PORT=3000
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_BASE=http://localhost:3001/api

# ---- Database (default: SQLite 单文件，零 Docker）----
# 相对路径在 `pnpm --filter @ai-camp/api exec prisma …`（cwd = apps/api）下解析，
# dev.db 会落在 apps/api/prisma/dev.db
DATABASE_URL=file:./prisma/dev.db

# Optional: 若改用 Postgres，可把上面换成 postgresql://user:pass@localhost:5432/ai_camp

# ---- Auth ----
JWT_SECRET=replace_me_with_a_strong_random_string
JWT_EXPIRES_IN=7d
COOKIE_NAME=ai_camp_token

# ---- Storage ----
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE=http://localhost:3001/uploads

# ---- Default AI Provider ----
DEFAULT_AI_PROVIDER=volcengine-ark

# ---- Volcengine Ark ----
# Leave ARK_API_KEY empty in .env.example. Put the real key in .env.local only.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_RESPONSES_PATH=/responses
ARK_VIDEO_TASKS_PATH=/contents/generations/tasks
ARK_IMAGES_PATH=/images/generations
ARK_TEXT_MODEL=
# Doubao Seedream 文生图 / 图生图模型，参见火山方舟控制台
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_VIDEO_MODEL=doubao-seedance-2-0-mini-260615
ARK_MULTIMODAL_MODEL=doubao-seed-2-1-pro-260628
# AI 小应用网页生成/迭代 — 走 /responses（与多模态 Pro 同模型）
ARK_WEB_MODEL=doubao-seed-2-1-pro-260628
ARK_CHAT_COMPLETIONS_PATH=/chat/completions

# ---- 并发闸门 / 排队提醒 ----
# 生图 / 生视频对接的方舟模型有账号级并发上限；多个学生同时提交超过该上限时，
# 系统会把超出的请求转为本地排队并提示"前面还有 XX 人"，而不是直接向供应商报错。
# 请按你在火山方舟控制台看到的真实并发配额调整下面两个值。
AI_IMAGE_MAX_CONCURRENCY=50
AI_VIDEO_MAX_CONCURRENCY=10

# ---- Volcengine Music (GenSongV4, AK/SK from 火山引擎密钥管理) ----
# Without these keys the music page falls back to mock audio in development.
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# ---- MiniMax Music ----
# 默认使用代码内置密钥（apps/api/src/modules/ai/providers/music-client.factory.ts），部署无需配置。
# 可选：通过环境变量覆盖 MUSIC_PROVIDER / MINIMAX_API_KEY / MINIMAX_MUSIC_MODEL
MUSIC_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_MUSIC_MODEL=music-3.0
